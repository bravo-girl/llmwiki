{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "llmwiki",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-20",
  "workers_dev": true,
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "GIT_PROVIDER": "github",
    "GITHUB_OWNER": "bravo-girl",
    "GITHUB_REPO": "llmwiki",
    "GITHUB_BRANCH": "main",
    "GEMMA_MODEL": "@cf/google/gemma-4-26b-a4b-it",
    "AUTO_WRITE": "true"
  }
}
